<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Script Library</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f0f0f;
            color: white;
        }
        .script-card {
            background: #1a1a1a;
            border: 1px solid #333;
            transition: 0.3s;
        }
        .script-card:hover {
            border-color: #a855f7;
            transform: translateY(-5px);
        }
    </style>
</head>
<body class="font-sans">

    <header class="p-6 text-center">
        <h1 class="text-4xl font-bold uppercase tracking-widest text-white">Script Library</h1>
        <p class="text-gray-400 mt-2">Premium utilities and game protections.</p>
    </header>

    <div class="max-w-xl mx-auto px-4 mb-10">
        <input type="text" placeholder="Search scripts..." 
            class="w-full p-4 rounded-lg bg-[#1a1a1a] border border-gray-700 focus:outline-none focus:border-purple-500 transition text-white">
    </div>

    <main class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-12">
        
        <div class="script-card p-5 rounded-2xl">
            <div class="h-40 bg-purple-900/20 rounded-xl mb-4 flex items-center justify-center">
                <span class="text-purple-500 font-bold text-lg">[FPS FLICK]</span>
            </div>
            <h2 class="text-xl font-bold mb-1 text-white">FPS FLICK</h2>
            <p class="text-xs text-gray-500 mb-4">PLACE ID: 136801880565837</p>
            <button onclick="copyScript('loadstring(game:HttpGet(\'https://example.com/script.lua\'))()')" 
                class="w-full py-2 bg-purple-600 hover:bg-purple-700 rounded-lg font-semibold transition">
                Copy Script
            </button>
        </div>

        <div class="script-card p-5 rounded-2xl">
            <div class="h-40 bg-blue-900/20 rounded-xl mb-4 flex items-center justify-center">
                <span class="text-blue-500 font-bold text-lg">[AUTO FARM]</span>
            </div>
            <h2 class="text-xl font-bold mb-1 text-white">Blox Fruits Hub</h2>
            <p class="text-xs text-gray-500 mb-4">PLACE ID: 2753915549</p>
            <button onclick="copyScript('loadstring(game:HttpGet(\'https://example.com/blox.lua\'))()')" 
                class="w-full py-2 bg-blue-600 hover:bg-blue-700 rounded-lg font-semibold transition">
                Copy Script
            </button>
        </div>

        <div class="script-card p-5 rounded-2xl">
            <div class="h-40 bg-red-900/20 rounded-xl mb-4 flex items-center justify-center">
                <span class="text-red-500 font-bold text-lg">[AIMBOT]</span>
            </div>
            <h2 class="text-xl font-bold mb-1 text-white">Universal Aimbot</h2>
            <p class="text-xs text-gray-500 mb-4">WORKS ON ALL GAMES</p>
            <button onclick="alert('Script copied!')" 
                class="w-full py-2 bg-red-600 hover:bg-red-700 rounded-lg font-semibold transition">
                Copy Script
            </button>
        </div>

    </main>

    <script>
        function copyScript(text) {
            navigator.clipboard.writeText(text).then(() => {
                alert("Script copied to clipboard!");
            });
        }
    </script>

</body>
</html>
